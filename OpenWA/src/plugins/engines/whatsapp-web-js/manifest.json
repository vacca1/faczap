{
    "id": "whatsapp-web.js",
    "name": "WhatsApp Web.js Engine",
    "version": "1.0.0",
    "type": "engine",
    "description": "Official WhatsApp-web.js engine adapter for OpenWA",
    "author": "OpenWA Team",
    "main": "index.ts",
    "provides": [
        "whatsapp-engine",
        "text-messages",
        "media-messages",
        "group-management"
    ],
    "configSchema": {
        "type": "object",
        "properties": {
            "sessionDataPath": {
                "type": "string",
                "title": "Session Data Path",
                "description": "Path to store session data",
                "default": "./data/sessions"
            },
            "headless": {
                "type": "boolean",
                "title": "Headless Mode",
                "description": "Run Puppeteer in headless mode",
                "default": true
            },
            "puppeteerArgs": {
                "type": "array",
                "title": "Puppeteer Arguments",
                "description": "Additional arguments for Puppeteer",
                "default": [
                    "--no-sandbox",
                    "--disable-setuid-sandbox"
                ]
            }
        }
    }
}